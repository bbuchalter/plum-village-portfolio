{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"slug": "forest-green",
					"color": "#2D5F2D",
					"name": "Forest Green"
				},
				{
					"slug": "dark-green",
					"color": "#1A3A1A",
					"name": "Dark Green"
				},
				{
					"slug": "cream",
					"color": "#FAF7F0",
					"name": "Cream"
				},
				{
					"slug": "warm-brown",
					"color": "#6B4423",
					"name": "Warm Brown"
				},
				{
					"slug": "light-sage",
					"color": "#E8EDE5",
					"name": "Light Sage"
				},
				{
					"slug": "muted-gold",
					"color": "#B8963E",
					"name": "Muted Gold"
				},
				{
					"slug": "soft-white",
					"color": "#FFFFFF",
					"name": "Soft White"
				},
				{
					"slug": "dark-text",
					"color": "#2C2C2C",
					"name": "Dark Text"
				}
			],
			"gradients": [
				{
					"slug": "morning-mist",
					"gradient": "linear-gradient(135deg, #FAF7F0 0%, #E8EDE5 100%)",
					"name": "Morning Mist"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"Cormorant Garamond\", Georgia, serif",
					"slug": "heading",
					"name": "Heading"
				},
				{
					"fontFamily": "\"Source Sans 3\", \"Segoe UI\", sans-serif",
					"slug": "body",
					"name": "Body"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.25rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "1.75rem",
					"name": "Extra Large"
				},
				{
					"slug": "xx-large",
					"size": "2.5rem",
					"name": "Double Extra Large"
				}
			]
		},
		"spacing": {
			"spacingSizes": [
				{
					"slug": "10",
					"size": "0.5rem",
					"name": "1"
				},
				{
					"slug": "20",
					"size": "1rem",
					"name": "2"
				},
				{
					"slug": "30",
					"size": "1.5rem",
					"name": "3"
				},
				{
					"slug": "40",
					"size": "2.5rem",
					"name": "4"
				},
				{
					"slug": "50",
					"size": "4rem",
					"name": "5"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1100px"
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--cream)",
			"text": "var(--wp--preset--color--dark-text)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.7"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "600",
					"lineHeight": "1.3"
				},
				"color": {
					"text": "var(--wp--preset--color--forest-green)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--warm-brown)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--forest-green)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--forest-green)",
					"text": "var(--wp--preset--color--cream)"
				},
				"border": {
					"radius": "4px"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--dark-green)",
						"text": "var(--wp--preset--color--cream)"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--small)"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--cream)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--muted-gold)"
							}
						}
					}
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--forest-green)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--warm-brown)"
							}
						}
					}
				}
			},
			"core/quote": {
				"border": {
					"left": {
						"color": "var(--wp--preset--color--muted-gold)",
						"width": "3px",
						"style": "solid"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontStyle": "italic"
				},
				"color": {
					"text": "var(--wp--preset--color--warm-brown)"
				}
			}
		}
	},
	"customTemplates": [
		{
			"name": "front-page",
			"title": "Front Page",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "single",
			"title": "Single Post",
			"postTypes": [
				"post"
			]
		},
		{
			"name": "page",
			"title": "Page",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "archive",
			"title": "Archive",
			"postTypes": [
				"post"
			]
		},
		{
			"name": "404",
			"title": "404"
		}
	],
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}
