{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "plum-village/course-grid",
  "version": "1.0.0",
  "title": "Course Grid",
  "category": "widgets",
  "icon": "grid-view",
  "description": "A dynamic grid of LearnDash courses with configurable columns, count, and display options.",
  "textdomain": "plum-village-blocks",
  "attributes": {
    "columns": {
      "type": "number",
      "default": 3
    },
    "count": {
      "type": "number",
      "default": 3
    },
    "showExcerpt": {
      "type": "boolean",
      "default": true
    },
    "showLessonCount": {
      "type": "boolean",
      "default": true
    }
  },
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}